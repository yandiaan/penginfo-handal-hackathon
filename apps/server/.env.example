NODE_ENV=development
PORT=3000

# Alibaba Model Studio (DashScope) — required for AI node execution
DASHSCOPE_API_KEY=your_key_here

# Daily budget limits per endpoint category (USD)
DAILY_BUDGET_VIDEO=2.00
DAILY_BUDGET_IMAGE=2.00
DAILY_BUDGET_TEXT=1.00
DAILY_BUDGET_PIPELINE=2.00

# Grace token -- append ?unlock=<token> to any URL to reset quota for that session (demo use only)
GRACE_TOKEN=your_secret_grace_token_here
