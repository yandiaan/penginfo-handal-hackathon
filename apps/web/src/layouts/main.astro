---
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title = 'ADIS AI' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="ADIS AI - Modular Content Generation Engine" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Preload landing page images so the browser fetches them in parallel
         with scripts, before JS even runs. Heaviest assets first. -->
    <link rel="preload" href="/about-ilustration.svg" as="image" type="image/svg+xml" />
    <link rel="preload" href="/background-about.jpg" as="image" type="image/jpeg" />
    <link rel="preload" href="/screenshot-1.png" as="image" type="image/png" />
    <link rel="preload" href="/line-white.svg" as="image" type="image/svg+xml" />
    <link rel="preload" href="/line-white-2.svg" as="image" type="image/svg+xml" />
    <link rel="preload" href="/logo.svg" as="image" type="image/svg+xml" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    overflow: hidden;
  }

  body {
    margin: 0;
    padding: 0;
    height: 100vh;
    overflow: hidden;
  }
</style>
