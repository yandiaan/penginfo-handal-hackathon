# Server Configuration
SERVER_PORT=3000

# Web Configuration
WEB_PORT=4321

# Alibaba Model Studio (DashScope) - Required for AI node execution
DASHSCOPE_API_KEY=your_api_key_here

# Node Environment
NODE_ENV=production

# Optional: Database configuration (if needed in future)
# DATABASE_URL=postgresql://user:password@localhost:5432/penginfo

# Optional: Redis configuration (if needed for caching)
# REDIS_URL=redis://localhost:6379

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
